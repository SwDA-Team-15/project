%%{init: {
  "theme": "dark",
  "themeVariables": {
    "primaryColor": "#1a1a2e",
    "primaryTextColor": "#ffffff",
    "primaryBorderColor": "#555555",
    "lineColor": "#888888",
    "secondaryColor": "#16213e",
    "tertiaryColor": "#0f3460",
    "fontFamily": "Arial, sans-serif",
    "fontSize": "13px",
    "clusterBkg": "#111122",
    "clusterBorder": "#444444"
  },
  "flowchart": {
    "htmlLabels": true,
    "curve": "basis",
    "rankSpacing": 80,
    "nodeSpacing": 40
  }
}}%%

flowchart TB

  %% ============================================================
  %% EXTERNAL ACTORS
  %% ============================================================
  subgraph ExternalActors["External Actors"]
    direction LR
    A1["📱 <b>Mobile App</b><br/>Users"]
    A2["🔑 <b>API</b><br/>Consumers"]
    A3["🌐 <b>Web Browser</b><br/>Users"]
    A4["⚙️ <b>Admin /</b><br/>DevOps"]
  end

  %% ============================================================
  %% SYSTEM BOUNDARY
  %% ============================================================
  subgraph SystemBoundary["System Boundary"]
    EXPRESS["🟠 <b>Express.js Application</b><br/><i>Node.js Web Framework</i><br/>Handles HTTP requests,<br/>routes, middleware pipeline,<br/>and response generation"]
  end

  %% ============================================================
  %% EXTERNAL SYSTEMS
  %% ============================================================
  subgraph ExternalSystems["External Systems"]
    direction LR
    S1["🌐 <b>CDN / Proxy</b><br/>Nginx / Cloudflare"]
    S2["📊 <b>Monitoring</b><br/>Sentry / Datadog"]
    S3[("🗄️ <b>Database</b><br/>PostgreSQL / MongoDB")]
    S4["⚫ <b>Cloud Storage</b><br/>S3 / GCS"]
    S5["📧 <b>Email Service</b><br/>SendGrid / SES"]
    S6["💳 <b>Payment Gateway</b><br/>Stripe"]
    S7["🔒 <b>Auth Provider</b><br/>OAuth / JWT"]
  end

  %% ============================================================
  %% CONNECTIONS: External Actors → System Boundary
  %% ============================================================
  A1 -->|"REST API Calls<br/>(JSON)"| EXPRESS
  A2 -->|"API Requests<br/>(Bearer Token)"| EXPRESS
  A3 -->|"HTTP/HTTPS Requests<br/>(HTML, Forms)"| EXPRESS
  A4 -->|"Deploy / Config"| EXPRESS

  %% ============================================================
  %% CONNECTIONS: System Boundary → External Systems
  %% ============================================================
  EXPRESS -->|"Proxied Requests"| S1
  EXPRESS -->|"Logs & Metrics"| S2
  EXPRESS -->|"SQL / NoSQL Queries"| S3
  EXPRESS -->|"File Upload/Download"| S4
  EXPRESS -->|"Send Notifications"| S5
  EXPRESS -->|"Process Payments"| S6
  EXPRESS -->|"Token Validation"| S7

  %% ============================================================
  %% STYLES
  %% ============================================================
  classDef actorStyle fill:#1a1a2e,stroke:#555,stroke-width:1px,color:#fff
  classDef expressStyle fill:#1a1a3e,stroke:#666,stroke-width:2px,color:#fff
  classDef systemStyle fill:#1a1a2e,stroke:#555,stroke-width:1px,color:#fff
  classDef dbStyle fill:#2a2a3e,stroke:#777,stroke-width:2px,color:#fff

  class A1,A2,A3,A4 actorStyle
  class EXPRESS expressStyle
  class S1,S2,S4,S5,S6,S7 systemStyle
  class S3 dbStyle
